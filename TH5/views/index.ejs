<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Blog</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <header>
        <h1>📝 Blog Cá Nhân</h1>
    </header>

    <div class="container">
        <a href="/blogposts/new" class="btn btn-primary">
            ➕ Tạo bài viết mới
        </a>

        <br><br>

        <% posts.forEach(post=> { %>
            <div class="post-card">
                <h2>
                    <%= post.title %>
                </h2>
                <p>
                    <%= post.body.substring(0, 150) %>
                        <%= post.body.length> 150 ? '...' : '' %>
                </p>
                <div class="post-actions">
                    <a href="/blogposts/<%= post._id %>" class="btn btn-success">👁 Xem</a>
                    <a href="/blogposts/<%= post._id %>/edit" class="btn btn-warning">✏️ Sửa</a>
                    <form action="/blogposts/<%= post._id %>/delete" method="POST" style="display:inline">
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Bạn có chắc muốn xóa?')">
                            🗑 Xóa
                        </button>
                    </form>
                </div>
            </div>
            <% }) %>

                <% if(posts.length===0) { %>
                    <div class="post-card" style="text-align:center; color:#999;">
                        Chưa có bài viết nào. Hãy tạo bài viết đầu tiên!
                    </div>
                    <% } %>
    </div>
</body>

</html>